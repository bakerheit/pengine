build/
build-*/
.cache/
.DS_Store
compile_commands.json
*.swp
.vscode/
.idea/
.claude/

# Generated IPL cell exports — produced lazily by the streamer on first
# encounter of a cell. Once we move to authored cells, specific files can
# be force-added.
assets/world/cells/*.ipl

# Cooked binary assets — built by the meshconv pipeline (see
# cmake/CookedAssets.cmake). Edit source art under assets/{characters,
# vehicles,weapons}/<pack>/ and rebuild; never commit cooked output.
assets/models/**/*.emesh
assets/models/**/*.eskel
assets/models/**/*.eanim
